# Clean-Backup Environment Variables (Docker)

# -----------------------------------------------------------------------------
# REQUIRED: The absolute path on your host machine where your photos are stored.
# This directory will be mounted read-write so the app can organize them.
# -----------------------------------------------------------------------------
MEDIA_PATH=/home/user/Pictures

# -----------------------------------------------------------------------------
# Optional Overrides (defaults shown below)
# -----------------------------------------------------------------------------
# The port the web UI will be accessible on (default 8080)
# CLEAN_BACKUP_PORT=8080

# Logging level (debug, info, warning, error)
# CLEAN_BACKUP_LOG_LEVEL=info

# If you are running on a low-resource machine (e.g., Raspberry Pi) or don't 
# want the AI ML models (content classification, face detection) to load into RAM, 
# you can disable them entirely.
# CLEAN_BACKUP_DISABLE_ML=1
